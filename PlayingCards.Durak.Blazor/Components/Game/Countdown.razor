@inject IJSRuntime JS
@implements IAsyncDisposable

<label class="speak-text" @ref="_label"></label>

@code {
    [Parameter, EditorRequired] public DateTime EndTime { get; set; }

    /// <summary>Вид отсчёта: "afk" | "take" | "beat" — задаёт шаблон и склонение в countdown.js.</summary>
    [Parameter, EditorRequired] public string Kind { get; set; } = default!;

    private ElementReference _label;
    private IJSObjectReference? _module;
    private DateTime? _appliedEnd;
    private string? _appliedKind;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_appliedEnd == EndTime && _appliedKind == Kind)
        {
            return;
        }

        _appliedEnd = EndTime;
        _appliedKind = Kind;

        var endMs = new DateTimeOffset(DateTime.SpecifyKind(EndTime, DateTimeKind.Utc)).ToUnixTimeMilliseconds();

        try
        {
            _module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Game/countdown.js");
            await _module.InvokeVoidAsync("start", _label, endMs, Kind);
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_module != null)
        {
            try
            {
                await _module.InvokeVoidAsync("stop", _label);
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}
