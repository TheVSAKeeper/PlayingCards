@implements IDisposable
@using System.Timers

<div class="error-toast" @onclick="Dismiss">@Message</div>

@code {
    [Parameter, EditorRequired] public string Message { get; set; } = default!;
    [Parameter] public EventCallback OnDismiss { get; set; }

    private System.Timers.Timer? _timer;

    protected override void OnInitialized()
    {
        _timer = new System.Timers.Timer(4000) { AutoReset = false };
        _timer.Elapsed += (_, _) => InvokeAsync(async () => await OnDismiss.InvokeAsync());
        _timer.Start();
    }

    private async Task Dismiss() => await OnDismiss.InvokeAsync();

    public void Dispose()
    {
        _timer?.Dispose();
    }
}
