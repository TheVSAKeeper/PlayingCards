@inject TableHolder TableHolder
@inject IJSRuntime JS
@inject PlayerSession Session
@implements IAsyncDisposable

@if (_view != null)
{
    <div class="game" @ref="_root">

        <header class="game-topbar">
            <button class="btn btn-info"
                    @onclick="StartGame"
                    hidden="@(!(CanStart))"
                    disabled="@(!CanStart)">
                Начать игру
            </button>
            <div class="topbar-right">
                <InvitePopup Table="Table.Id" />
                <button class="btn btn-bot"
                        @onclick="AddBot"
                        hidden="@(!CanAddBot)"
                        disabled="@(!CanAddBot)">
                    ＋ Бот
                </button>
                <button class="btn btn-warning" @onclick="Leave">Выйти из-за стола</button>
            </div>
        </header>

        <section class="opponents">
            <PlayersRing View="_view" CanKick="AmOwner" OnKick="Kick" />
        </section>

        <section class="table-center">
            <DiscardPile View="_view" />
            <div class="field" data-drop="field">
                @{
                    var amDefender = _view.DefencePlayerIndex == _view.MyPlayerIndex;
                }
                @for (var i = 0; i < (_view.Cards?.Length ?? 0); i++)
                {
                    var idx = i;
                    var fc = _view.Cards![idx];
                    var covered = fc.DefenceCard != null;
                    var clickable = amDefender && !covered;
                    var dim = !Session.NoHints && clickable && !_fieldSelectable.Contains(idx);
                    var attackCss = "attack-card"
                        + (clickable ? "" : " static")
                        + (dim ? " dimmed" : "");

                    <div class="field-card" data-field-index="@idx" @key="(fc.AttackCard!.Rank * 4 + fc.AttackCard.Suit)">
                        <CardView Card="fc.AttackCard!"
                                  CssClass="@attackCss"
                                  Active="_fieldActive.Contains(idx)"
                                  OnClick="() => ToggleField(idx)" />
                        @if (fc.DefenceCard != null)
                        {
                            <CardView Card="fc.DefenceCard" CssClass="defence-card" />
                        }
                    </div>
                }
            </div>
            <Deck View="_view" />
        </section>

        <section class="me">
            <div class="hand">
                @for (var i = 0; i < (_view.MyCards?.Length ?? 0); i++)
                {
                    var idx = i;
                    var card = _view.MyCards![idx];
                    var selectable = _handSelectable.Contains(idx);
                    var selected = _handActive.Contains(idx);
                    var handCss = !selectable && !Session.NoHints ? "dimmed" : "";

                    <div class="hand-slot"
                         data-hand-index="@idx"
                         data-playable="@(selectable ? "true" : "false")"
                         @key="(card.Rank * 4 + card.Suit)">
                        <CardView Card="card"
                                  CssClass="@handCss"
                                  Active="selected"
                                  OnClick="() => ToggleHand(idx)" />
                    </div>
                }
            </div>

            @if (_contextHint != null && !Session.NoHints)
            {
                <div class="context-hint">@_contextHint</div>
            }

            <div class="me-actions">
                <button class="btn btn-info"
                        @onclick="Play"
                        disabled="@(!CanPlay)">
                    Сыграть
                </button>
                <button class="btn btn-warning"
                        @onclick="Take"
                        disabled="@(!CanTake)">
                    Забрать карты
                </button>

                <button class="btn btn-beat"
                        @onclick="Beat"
                        hidden="@(!_view.CanBeat)"
                        disabled="@(!_view.CanBeat)">
                    Бито
                </button>
            </div>

            <PlayerBadge Name="@Me.Player.Name"
                         GameIndex="_view.MyPlayerIndex"
                         IsActive="_view.MyPlayerIndex == _view.ActivePlayerIndex"
                         IsDefence="_view.MyPlayerIndex == _view.DefencePlayerIndex"
                         IsLooser="_view.MyPlayerIndex == _view.LooserPlayerIndex"
                         Reply="@_view.MyReply"
                         AfkEndTime="_view.AfkEndTime"
                         StopRoundStatus="_view.StopRoundStatus"
                         StopRoundEndDate="_view.StopRoundEndDate" />
        </section>

        @if (_error != null)
        {
            <ErrorToast Message="@_error" OnDismiss="() => _error = null" />
        }

    </div>
}

@code {
    [Parameter, EditorRequired] public Table Table { get; set; } = default!;
    [Parameter, EditorRequired] public TablePlayer Me { get; set; } = default!;
    [Parameter] public EventCallback OnChanged { get; set; }

    private TableModel? _view;
    private readonly HashSet<int> _handActive = [];
    private readonly HashSet<int> _fieldActive = [];
    private HashSet<int> _handSelectable = [];
    private HashSet<int> _fieldSelectable = [];
    private string? _contextHint;
    private string? _error;
    private Table? _subscribed;

    /// <summary>Я — владелец стола: показываем кик соперникам и кнопку «Начать».</summary>
    private bool AmOwner => _view is { } v && v.MyPlayerIndex == v.OwnerIndex;

    private BoardSnapshot? _prevSnapshot;
    private BoardDiff? _pendingDiff;
    private readonly HashSet<string> _justPlayedByMe = [];
    private HandSortMode? _appliedSort;

    private ElementReference _root;
    private IJSObjectReference? _dndModule;
    private DotNetObjectReference<GameTable>? _selfRef;
    private bool _dndInited;

    protected override void OnInitialized()
    {
        Session.SettingsChanged += OnSettingsChanged;
    }

    protected override void OnParametersSet()
    {
        if (!ReferenceEquals(_subscribed, Table))
        {
            if (_subscribed != null) _subscribed.Changed -= OnTableChanged;
            Table.Changed += OnTableChanged;
            _subscribed = Table;
            _appliedSort = null;
        }

        Rebuild();
        _ = ApplySortIfNeededAsync();
    }

    /// <summary>
    /// Настройки игрока изменились: перерисовываемся (подсказки F7 могли скрыться/появиться)
    /// и, если поменялся режим сортировки, просим сервер пересортировать руку (push вернёт новый порядок).
    /// </summary>
    private void OnSettingsChanged() => InvokeAsync(async () =>
    {
        await ApplySortIfNeededAsync();
        StateHasChanged();
    });

    /// <summary>
    /// Шлёт <see cref="Table.SetSortMode"/> только при реальной смене режима — не на каждый push.
    /// Клиент НЕ переупорядочивает руку сам: протокол адресует карты индексом в серверном порядке,
    /// поэтому достаточно дёрнуть серверный ресорт, а его push перерисует новый порядок.
    /// </summary>
    private async Task ApplySortIfNeededAsync()
    {
        if (_view == null || _view.MyPlayerIndex < 0)
        {
            return;
        }

        if (_appliedSort == Session.HandSort)
        {
            return;
        }

        _appliedSort = Session.HandSort;

        try
        {
            Table.SetSortMode(Me.AuthSecret, Session.HandSort);
        }
        catch (BusinessException)
        {
            _appliedSort = null;
        }

        await Task.CompletedTask;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_view != null && !_dndInited)
        {
            _dndInited = true;
            _selfRef = DotNetObjectReference.Create(this);
            _dndModule = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Game/GameTable.razor.js");
            await _dndModule.InvokeVoidAsync("init", _root, _selfRef);
        }

        if (_pendingDiff is { IsEmpty: false } diff && _dndModule != null && !firstRender)
        {
            _pendingDiff = null;

            try
            {
                await _dndModule.InvokeVoidAsync("animate", diff.ToPayload());
            }
            catch (JSDisconnectedException)
            {
            }
            catch (JSException)
            {
            }
        }
        else
        {
            _pendingDiff = null;
        }
    }

    private void OnTableChanged() => InvokeAsync(() =>
    {
        Rebuild();
        StateHasChanged();
    });

    private void Rebuild()
    {
        if (Table.Players.All(x => x.Player != Me.Player))
        {
            _view = null;
            _prevSnapshot = null;
            return;
        }

        TableModel view;

        try
        {
            view = TableViewBuilder.BuildTable(Table, Me);
        }
        catch (Exception)
        {
            return;
        }

        if (view.MyPlayerIndex < 0)
        {
            _view = null;
            _prevSnapshot = null;
            return;
        }

        var prev = _prevSnapshot;
        var next = BoardSnapshot.From(view);

        _view = view;
        _handActive.RemoveWhere(i => i >= (_view.MyCards?.Length ?? 0));
        _fieldActive.RemoveWhere(i => i >= (_view.Cards?.Length ?? 0));
        UpdateSelectables();

        _pendingDiff = BoardDiff.Compute(prev, next, _justPlayedByMe);
        _justPlayedByMe.Clear();
        _prevSnapshot = next;
    }

    private void UpdateSelectables()
    {
        if (_view == null) return;
        _handSelectable = PlayLogic.GetPlayableHandIndexes(_view, _handActive, _fieldActive);
        _fieldSelectable = PlayLogic.GetBeatableFieldIndexes(_view, _handActive);
        _contextHint = PlayLogic.GetContextHint(_view);
    }

    private bool CanStart => _view!.Status != (int)GameStatus.InProcess
        && _view.Players.Length > 0
        && _view.MyPlayerIndex == _view.OwnerIndex;

    private bool CanAddBot => _view!.Status != (int)GameStatus.InProcess
        && _view.Players.Length + 1 < 6
        && _view.MyPlayerIndex == _view.OwnerIndex;

    private bool CanTake => _view!.Cards is { Length: > 0 }
        && _view.MyPlayerIndex == _view.DefencePlayerIndex
        && _view.Cards.Any(c => c.DefenceCard == null);

    private bool CanPlay => PlayLogic.CanPlayCards(_view!, [.. _handActive], [.. _fieldActive]);

    private void ToggleHand(int i)
    {
        if (_view!.Status == (int)GameStatus.InProcess && !_handSelectable.Contains(i)) return;

        if (!_handActive.Add(i)) _handActive.Remove(i);
        UpdateSelectables();
    }

    private void ToggleField(int i)
    {
        if (_view!.Cards![i].DefenceCard != null) return;
        if (_view.DefencePlayerIndex != _view.MyPlayerIndex) return;
        if (_view.Status == (int)GameStatus.InProcess && !_fieldSelectable.Contains(i)) return;

        if (!_fieldActive.Add(i)) _fieldActive.Remove(i);
        UpdateSelectables();
    }

    private async Task StartGame()
    {
        await Guard(() => Table.StartGame());
    }

    private async Task AddBot()
    {
        await Guard(() => TableHolder.AddBot(Table.Id, Me.AuthSecret));
    }

    private async Task Play()
    {
        var hand = _handActive.OrderBy(x => x).ToArray();
        var field = _fieldActive.OrderBy(x => x).ToArray();
        int? attackIndex = field.Length > 0 ? field[0] : null;

        MarkPlayedByMe(hand);

        await Guard(() => Table.PlayCards(Me.AuthSecret, hand, attackIndex));
        _handActive.Clear();
        _fieldActive.Clear();
        UpdateSelectables();
    }

    /// <summary>Запоминает идентичность сыгранных мной карт (для фильтра «своего» подкида в диффе анимаций).</summary>
    private void MarkPlayedByMe(int[] handIndexes)
    {
        var my = _view?.MyCards;

        if (my == null)
        {
            return;
        }

        foreach (var i in handIndexes)
        {
            if (i >= 0 && i < my.Length)
            {
                _justPlayedByMe.Add(BoardSnapshot.Key(my[i]));
            }
        }
    }

    /// <summary>
    /// Зоны сброса для карты руки <paramref name="handIndex"/>: поле (атака/подкид)
    /// и/или индексы неотбитых атакующих карт, которые эта карта побьёт (отбой).
    /// Вызывается из GameTable.razor.js в момент захвата — один раз за перетаскивание.
    /// </summary>
    [JSInvokable]
    public DropTargets GetDropTargets(int handIndex)
    {
        if (_view?.MyCards == null
            || handIndex < 0
            || handIndex >= _view.MyCards.Length
            || !_handSelectable.Contains(handIndex))
        {
            return new DropTargets(false, []);
        }

        int[] hand = [handIndex];
        var field = PlayLogic.CanPlayCards(_view, hand, []);

        var defence = new List<int>();
        var cards = _view.Cards ?? [];

        for (var i = 0; i < cards.Length; i++)
        {
            if (cards[i].DefenceCard == null
                && cards[i].AttackCard != null
                && PlayLogic.CanPlayCards(_view, hand, [i]))
            {
                defence.Add(i);
            }
        }

        return new DropTargets(field, [.. defence]);
    }

    /// <summary>
    /// Карту из руки бросили на зону: -1 — поле (атака/подкид), иначе индекс атакующей
    /// карты (отбой). Возвращает true при успешном ходе — JS играет снап и искры; при
    /// false — упругий возврат карты в руку.
    /// </summary>
    [JSInvokable]
    public async Task<bool> OnCardDropped(int handIndex, int fieldIndex)
    {
        if (_view == null)
        {
            return false;
        }

        int[] hand = [handIndex];
        int[] field = fieldIndex >= 0 ? [fieldIndex] : [];
        int? attackIndex = fieldIndex >= 0 ? fieldIndex : null;

        if (!PlayLogic.CanPlayCards(_view, hand, field))
        {
            return false;
        }

        MarkPlayedByMe(hand);

        try
        {
            Table.PlayCards(Me.AuthSecret, hand, attackIndex);
        }
        catch (BusinessException ex)
        {
            _error = ex.Message;
            await OnChanged.InvokeAsync();
            return false;
        }

        _handActive.Clear();
        _fieldActive.Clear();
        UpdateSelectables();
        await OnChanged.InvokeAsync();
        return true;
    }

    public record DropTargets(bool Field, int[] Defence);

    private async Task Take()
    {
        await Guard(() => Table.Take(Me.AuthSecret));
    }

    /// <summary>
    /// «Бито»: атакующий объявляет, что больше не подкидывает (issue F5). Раунд закроется, когда
    /// «Бито» скажут все атакующие, иначе — по общему таймеру. Серверный <see cref="Table.Beat"/>
    /// валидирует окно/роль и кидает <see cref="BusinessException"/>, которую Guard сольёт в ErrorToast.
    /// </summary>
    private async Task Beat()
    {
        await Guard(() => Table.Beat(Me.AuthSecret));
    }

    /// <summary>
    /// Выгнать соперника (бота или человека) по его игровому индексу — доступно только владельцу,
    /// в лобби и в игре. Нарушения (не владелец/неверная цель) серверный <see cref="TableHolder.Kick"/>
    /// кидает <see cref="BusinessException"/>, которую Guard сольёт в ErrorToast.
    /// </summary>
    private async Task Kick(int gameIndex)
    {
        await Guard(() => TableHolder.Kick(Me.AuthSecret, Table.Id, gameIndex));
    }

    private async Task Leave()
    {
        TableHolder.Leave(Me.AuthSecret);
        await OnChanged.InvokeAsync();
    }

    private async Task Guard(Action action)
    {
        try
        {
            action();
        }
        catch (BusinessException ex)
        {
            _error = ex.Message;
        }

        await OnChanged.InvokeAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (_subscribed != null) _subscribed.Changed -= OnTableChanged;
        Session.SettingsChanged -= OnSettingsChanged;

        if (_dndModule != null)
        {
            try
            {
                await _dndModule.InvokeVoidAsync("dispose");
                await _dndModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }

        _selfRef?.Dispose();
    }

    private sealed record BoardSnapshot(
        int Deck,
        int Discard,
        string[] FieldAttacks,
        string?[] FieldDefences,
        int? ActiveIndex,
        int? DefenceIndex,
        int MyIndex,
        string[] MyCards,
        Dictionary<int, int> CountsByGameIndex)
    {
        public static string Key(CardModel? c) => c == null ? "" : $"{c.Rank}/{c.Suit}";

        public static BoardSnapshot From(TableModel v)
        {
            var cards = v.Cards ?? [];
            var attacks = cards.Select(c => Key(c.AttackCard)).ToArray();
            var defences = cards.Select(c => c.DefenceCard != null ? Key(c.DefenceCard) : null).ToArray();
            var my = (v.MyCards ?? []).Select(Key).ToArray();

            var counts = new Dictionary<int, int>();

            foreach (var p in v.Players ?? [])
            {
                counts[p.Index] = p.CardsCount;
            }

            if (v.MyPlayerIndex >= 0)
            {
                counts[v.MyPlayerIndex] = my.Length;
            }

            return new BoardSnapshot(
                v.DeckCardsCount,
                v.DiscardCardsCount,
                attacks,
                defences,
                v.ActivePlayerIndex,
                v.DefencePlayerIndex,
                v.MyPlayerIndex,
                my,
                counts);
        }
    }

    private sealed record CardFace(int Rank, int Suit);

    private sealed record ThrowIn(int Rank, int Suit, int FieldIndex, int ThrowerIndex);

    /// <summary>Карта защиты, легшая на слот <paramref name="FieldIndex"/>, летит от бейджа защищающегося.</summary>
    private sealed record Cover(int Rank, int Suit, int FieldIndex, int DefenderIndex);

    private sealed record DrawTo(string ToType, int BadgeIndex, int Count);

    private sealed record BoardDiff(
        List<ThrowIn> ThrowIns,
        List<Cover> Covers,
        List<DrawTo> Draws,
        int TakeTarget,
        List<CardFace> TakeCards,
        List<CardFace> BeatCards)
    {
        public bool IsEmpty => ThrowIns.Count == 0 && Covers.Count == 0 && Draws.Count == 0 && TakeCards.Count == 0 && BeatCards.Count == 0;

        /// <summary>
        /// Плоская camelCase-проекция для JS (GameTable.razor.js#animate). Имена фиксируем явно,
        /// чтобы анимации не зависели от того, как JS-интероп сериализует имена свойств записей.
        /// </summary>
        public object ToPayload() => new
        {
            throwIns = ThrowIns.Select(t => new { rank = t.Rank, suit = t.Suit, fieldIndex = t.FieldIndex, throwerIndex = t.ThrowerIndex }),
            covers = Covers.Select(c => new { rank = c.Rank, suit = c.Suit, fieldIndex = c.FieldIndex, defenderIndex = c.DefenderIndex }),
            draws = Draws.Select(d => new { toType = d.ToType, badgeIndex = d.BadgeIndex, count = d.Count }),
            takeTarget = TakeTarget,
            takeCards = TakeCards.Select(c => new { rank = c.Rank, suit = c.Suit }),
            beatCards = BeatCards.Select(c => new { rank = c.Rank, suit = c.Suit }),
        };

        private static CardFace Face(string key)
        {
            var parts = key.Split('/');
            return int.TryParse(parts.ElementAtOrDefault(0), out var r) && int.TryParse(parts.ElementAtOrDefault(1), out var s)
                ? new CardFace(r, s)
                : new CardFace(0, 0);
        }

        public static BoardDiff Compute(BoardSnapshot? prev, BoardSnapshot next, HashSet<string> justPlayedByMe)
        {
            var throwIns = new List<ThrowIn>();
            var covers = new List<Cover>();
            var draws = new List<DrawTo>();
            var takeCards = new List<CardFace>();
            var beatCards = new List<CardFace>();
            var takeTarget = -1;

            if (prev == null || prev.MyIndex != next.MyIndex)
            {
                return new BoardDiff(throwIns, covers, draws, takeTarget, takeCards, beatCards);
            }

            var prevAttackSet = new HashSet<string>(prev.FieldAttacks);
            var nextField = next.FieldAttacks;
            var prevFieldCount = prev.FieldAttacks.Length;
            var nextFieldCount = nextField.Length;

            if (nextFieldCount > prevFieldCount && next.ActiveIndex is { } thrower)
            {
                var seen = new HashSet<string>();

                for (var i = 0; i < nextField.Length; i++)
                {
                    var key = nextField[i];

                    if (!prevAttackSet.Contains(key) && !justPlayedByMe.Contains(key) && seen.Add(key))
                    {
                        var face = Face(key);
                        throwIns.Add(new ThrowIn(face.Rank, face.Suit, i, thrower));
                    }
                }
            }

            if (next.DefenceIndex is { } defender)
            {
                for (var i = 0; i < next.FieldDefences.Length; i++)
                {
                    var def = next.FieldDefences[i];
                    var prevDef = i < prev.FieldDefences.Length ? prev.FieldDefences[i] : null;

                    if (def == null || prevDef != null || justPlayedByMe.Contains(def))
                    {
                        continue;
                    }

                    var face = Face(def);
                    covers.Add(new Cover(face.Rank, face.Suit, i, defender));
                }
            }

            if (prevFieldCount > 0 && nextFieldCount == 0)
            {
                var faces = prev.FieldAttacks.Concat(prev.FieldDefences.OfType<string>()).Select(Face).ToList();

                if (next.Discard > prev.Discard)
                {
                    beatCards.AddRange(faces);
                }
                else
                {
                    takeTarget = prev.DefenceIndex ?? -1;
                    takeCards.AddRange(faces);
                }
            }

            var dealStage = nextFieldCount == 0 || prevFieldCount == 0;

            if (dealStage)
            {
                foreach (var (gi, cnt) in next.CountsByGameIndex)
                {
                    var before = prev.CountsByGameIndex.TryGetValue(gi, out var b) ? b : cnt;
                    var grew = cnt - before;

                    if (grew <= 0)
                    {
                        continue;
                    }

                    if (takeTarget == gi)
                    {
                        continue;
                    }

                    if (gi == next.MyIndex)
                    {
                        draws.Add(new DrawTo("hand", -1, grew));
                    }
                    else
                    {
                        draws.Add(new DrawTo("badge", gi, grew));
                    }
                }
            }

            return new BoardDiff(throwIns, covers, draws, takeTarget, takeCards, beatCards);
        }
    }
}
