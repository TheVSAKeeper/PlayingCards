<div class="play-card @(Active ? "active" : "") @CssClass"
     role="@(Interactive ? "button" : null)"
     tabindex="@(Interactive ? 0 : null)"
     aria-pressed="@AriaPressed"
     aria-label="@Label"
     @onclick="OnClickInternal"
     @onkeydown="OnKeyDown">
    <div class="card-index card-index-tl @(IsRed ? "red" : "")">
        <span class="card-rank">@RankText</span>
        <span class="card-suit">@SuitText</span>
    </div>
    <div class="card-pip @(IsRed ? "red" : "")">@SuitText</div>
    <div class="card-index card-index-br @(IsRed ? "red" : "")">
        <span class="card-rank">@RankText</span>
        <span class="card-suit">@SuitText</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public CardModel Card { get; set; } = default!;
    [Parameter] public bool Active { get; set; }
    [Parameter] public string? CssClass { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private bool Interactive => OnClick.HasDelegate;
    private bool IsRed => CardGlyph.IsRed(Card.Suit);
    private string SuitText => CardGlyph.Suit(Card.Suit);
    private string RankText => CardGlyph.Rank(Card.Rank);
    private string Label => $"{RankText} {CardGlyph.SuitName(Card.Suit)}";
    private string? AriaPressed => Interactive ? (Active ? "true" : "false") : null;

    private async Task OnClickInternal()
    {
        if (Interactive)
        {
            await OnClick.InvokeAsync();
        }
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (Interactive && e.Key is "Enter" or " " or "Spacebar")
        {
            await OnClick.InvokeAsync();
        }
    }
}
