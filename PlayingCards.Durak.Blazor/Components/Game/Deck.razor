<div class="deck">
    <div class="deck-cards" data-deck-anchor>
        @if (View.Trump != null && View.DeckCardsCount > 0)
        {
            @if (View.DeckCardsCount > 1)
            {
                <CardBack CssClass="deck-pile" />
            }
            <CardView Card="View.Trump" />
            @if (View.DeckCardsCount > 1)
            {
                <span class="deck-count">@View.DeckCardsCount</span>
            }
        }
    </div>
    @if (View.Trump != null && View.DeckCardsCount == 0)
    {
        <div class="trump-info">Козырь: @CardGlyph.Suit(View.Trump.Suit)</div>
    }
</div>

@code {
    [Parameter, EditorRequired] public TableModel View { get; set; } = default!;
}
