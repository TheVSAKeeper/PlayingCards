@page "/"
@rendermode InteractiveServer
@inject PlayerSession Session
@inject TableHolder TableHolder
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>Дурач☻к</PageTitle>

@if (!_loaded)
{
    <div class="screen-loading">
        <span class="suit-spinner">♠ ♦ ♣ ♥</span>
        <p>Загрузка…</p>
    </div>
}
else if (!Session.IsAuthenticated)
{
    <LoginPanel OnLoggedIn="OnSessionChanged" />
}
else
{
    <UserBar OnLoggedOut="OnLoggedOut" />

    @if (_currentTable == null)
    {
        <Lobby PlayerSecret="@(Session.Secret!)" PlayerName="@(Session.Name!)" ExternalError="@_joinError" OnChanged="Refresh" />
    }
    else
    {
        <GameTable Table="_currentTable" Me="_me!" OnChanged="Refresh" />
    }
}

@code {
    /// <summary>
    /// Идентификатор стола из ссылки-приглашения (<c>/?table={guid}</c>) — авто-подсадка после входа.
    /// </summary>
    [SupplyParameterFromQuery(Name = "table")]
    public string? TableParam { get; set; }

    private bool _loaded;
    private bool _disposed;
    private Table? _currentTable;
    private TablePlayer? _me;
    private string? _joinError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.LoadAsync();
            _loaded = true;
            TableHolder.Changed += OnHolderChanged;
            await OnSessionChanged();
        }
    }

    private void OnHolderChanged()
    {
        if (_disposed)
        {
            return;
        }

        try
        {
            InvokeAsync(Refresh);
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task OnSessionChanged()
    {
        Refresh();
        await TryAutoJoinAsync();
    }

    /// <summary>
    /// Если пришли по ссылке-приглашению и ещё не сидим за столом — подсаживаемся за указанный стол.
    /// Ссылку в адресе после попытки убираем, чтобы повторный рендер/выход не переподсаживал.
    /// </summary>
    private async Task TryAutoJoinAsync()
    {
        if (!Session.IsAuthenticated || _currentTable != null || !Guid.TryParse(TableParam, out var tableId))
        {
            return;
        }

        try
        {
            TableHolder.Join(tableId, Session.Secret!, Session.Name!);
            _joinError = null;
        }
        catch (BusinessException ex)
        {
            _joinError = ex.Message;
        }

        Navigation.NavigateTo("/", replace: true);
        Refresh();
        await Task.CompletedTask;
    }

    private void Refresh()
    {
        if (Session.IsAuthenticated)
        {
            _currentTable = TableHolder.GetBySecret(Session.Secret!, out _me);
            if (_currentTable != null)
                _joinError = null;
        }
        else
        {
            _currentTable = null;
            _me = null;
        }

        StateHasChanged();
    }

    /// <summary>
    /// Выход выполняет <see cref="UserBar"/> (встаёт из-за стола + сбрасывает личность);
    /// здесь лишь перестраиваем экран обратно на панель логина.
    /// </summary>
    private void OnLoggedOut() => Refresh();

    public void Dispose()
    {
        _disposed = true;
        TableHolder.Changed -= OnHolderChanged;
    }
}
