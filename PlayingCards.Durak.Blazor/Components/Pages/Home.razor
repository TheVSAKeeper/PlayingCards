@page "/"
@rendermode InteractiveServer
@inject PlayerSession Session
@inject TableHolder TableHolder
@implements IDisposable

<PageTitle>Дурак</PageTitle>

@if (!_loaded)
{
    <div class="screen-loading">
        <span class="suit-spinner">♠ ♦ ♣ ♥</span>
        <p>Загрузка…</p>
    </div>
}
else if (!Session.IsAuthenticated)
{
    <LoginPanel OnLoggedIn="OnSessionChanged" />
}
else
{
    <div class="top-bar">
        <span class="name-label">@Session.Name</span>
        <button class="btn btn-info" @onclick="Logout">Выйти</button>
    </div>

    @if (_currentTable == null)
    {
        <Lobby PlayerSecret="@(Session.Secret!)" PlayerName="@(Session.Name!)" OnChanged="Refresh" />
    }
    else
    {
        <GameTable Table="_currentTable" Me="_me!" OnChanged="Refresh" />
    }
}

@code {
    private bool _loaded;
    private bool _disposed;
    private Table? _currentTable;
    private TablePlayer? _me;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Session.LoadAsync();
            _loaded = true;
            TableHolder.Changed += OnHolderChanged;
            await OnSessionChanged();
        }
    }

    private void OnHolderChanged()
    {
        if (_disposed)
        {
            return;
        }

        try
        {
            InvokeAsync(Refresh);
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task OnSessionChanged()
    {
        Refresh();
        await Task.CompletedTask;
    }

    private void Refresh()
    {
        if (Session.IsAuthenticated)
        {
            _currentTable = TableHolder.GetBySecret(Session.Secret!, out _me);
        }
        else
        {
            _currentTable = null;
            _me = null;
        }

        StateHasChanged();
    }

    private async Task Logout()
    {
        if (_currentTable != null)
        {
            TableHolder.Leave(Session.Secret!);
        }

        await Session.LogoutAsync();
        Refresh();
    }

    public void Dispose()
    {
        _disposed = true;
        TableHolder.Changed -= OnHolderChanged;
    }
}
